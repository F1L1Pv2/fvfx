/*
Name: Translate
Description: Move Video Around
Author: F1L1P
Input: float OffsetX
Input: float OffsetY
*/

void main() {
    vec2 newUV = uv + vec2(-Input.OffsetX,Input.OffsetY);
    vec4 color = texture(imageIN, newUV);
    if(newUV.x < 0 || newUV.x > 1.0 || newUV.y < 0 || newUV.y > 1.0){
        outColor = vec4(0,0,0,0);
        return;
    }
    outColor = color;
}